# ============================================================================
# MATTIN AI — Environment Configuration
# ============================================================================
# Quick start:
#   cp .env.example .env
#   Edit the variables marked [REQUIRED] below
#   docker-compose up -d
#
# This file is used by docker-compose.yaml.
# For backend-only local dev, see backend/.env.example.
# For frontend-only local dev, see frontend/.env.example.
# ============================================================================


# ============================================================================
# AUTHENTICATION [REQUIRED — choose one mode]
# ============================================================================
# FAKE : Simple email login for development (no external provider needed)
# OIDC : Microsoft Entra ID / Azure AD for production
AICT_LOGIN=FAKE

# Comma-separated list of emails that receive OMNIADMIN privileges [REQUIRED]
AICT_OMNIADMINS=admin@example.com


# ============================================================================
# SECURITY [REQUIRED in production]
# ============================================================================
# Secret key for signing JWT tokens.
# Generate a new one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-in-production-generate-a-random-key

JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24


# ============================================================================
# DATABASE
# ============================================================================
# These values work out of the box with docker-compose.
# Only change them if you need specific credentials.

DATABASE_USER=mattin
DATABASE_PASSWORD=mattin_secure_2024
DATABASE_NAME=mattin_ai
DATABASE_PORT=5432

# For local dev (without Docker), also set:
# DATABASE_HOST=localhost
# SQLALCHEMY_DATABASE_URI=postgresql://mattin:mattin_secure_2024@localhost:5432/mattin_ai


# ============================================================================
# AI API KEYS [OPTIONAL]
# ============================================================================
# You can set API keys here or from the web interface.
# Only needed when you want to use AI models from these providers.
#
# Get your keys at:
#   OpenAI:    https://platform.openai.com/api-keys
#   Anthropic: https://console.anthropic.com/
#   Mistral:   https://console.mistral.ai/

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=


# ============================================================================
# URLS
# ============================================================================
# Docker Compose defaults (backend on 8000, frontend served by Nginx on 3000):
VITE_API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# For local dev (without Docker):
# VITE_API_BASE_URL=http://localhost:8000
# FRONTEND_URL=http://localhost:5173

# For production, use your actual domains:
# VITE_API_BASE_URL=https://api.yourdomain.com
# FRONTEND_URL=https://yourdomain.com

# Base URL for generating MCP endpoint URLs exposed to external clients
# (Claude Desktop, Cursor, etc.)
# MCP_BASE_URL=http://localhost:8000

# Base URL used to build signed image URLs. If unset, images are passed as base64.
# AICT_BASE_URL=http://localhost:5173


# ============================================================================
# MICROSOFT ENTRA ID / AZURE AD  (only if AICT_LOGIN=OIDC)
# ============================================================================
# Get these values from: Azure Portal > App registrations > Your app

ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# Token type to accept and validate:
#   ID_TOKEN     — OIDC authentication (aud=client_id). No "Expose an API" needed.
#   ACCESS_TOKEN — OAuth 2.0 authorization (aud=api://client_id). Requires "Expose an API" in Azure.
ENTRA_TOKEN_TYPE=ACCESS_TOKEN

# JWT validation settings (advanced — defaults are correct for most deployments)
# ENTRA_VALIDATE_AUDIENCE=true
# ENTRA_VALIDATE_ISSUER=true
# ENTRA_LEEWAY=0
# ENTRA_API_VERSION=v1.0


# ============================================================================
# OIDC — FRONTEND  (only if AICT_LOGIN=OIDC)
# ============================================================================
VITE_OIDC_ENABLED=false
# VITE_OIDC_AUTHORITY=https://login.microsoftonline.com/{tenant-id}/v2.0
# VITE_OIDC_CLIENT_ID=your-azure-client-id
# VITE_OIDC_REDIRECT_URI=http://localhost:3000/auth/success
# VITE_OIDC_SCOPE=openid profile email
# VITE_OIDC_AUDIENCE=


# ============================================================================
# VECTOR DATABASE
# ============================================================================
# PGVECTOR  — uses the existing PostgreSQL connection (default, no extra service)
# QDRANT    — uses the Qdrant container already included in docker-compose.yaml
VECTOR_DB_TYPE=PGVECTOR

# Qdrant (only if VECTOR_DB_TYPE=QDRANT)
# When running via docker-compose, use the service hostname:
# QDRANT_URL=http://qdrant:6333
# For local dev outside Docker:
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=                    # Optional — only for Qdrant Cloud
# QDRANT_PREFER_GRPC=false           # Set true for higher throughput (uses port 6334)


# ============================================================================
# FILE STORAGE
# ============================================================================
REPO_BASE_FOLDER=./data/repositories

# TMP_BASE_FOLDER=./data/tmp


# ============================================================================
# LANGSMITH  (optional — LLM tracing per app)
# ============================================================================
# LANGSMITH_TRACING=false
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=


# ============================================================================
# SAAS MODE  (only if AICT_DEPLOYMENT_MODE=saas)
# ============================================================================
# Deployment mode: self_managed (default) or saas
AICT_DEPLOYMENT_MODE=self_managed

# Stripe (required in SaaS mode — use test keys for local dev)
# Get keys at: https://dashboard.stripe.com/apikeys
# STRIPE_API_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID_STARTER=price_...
# STRIPE_PRICE_ID_PRO=price_...

# Email / SMTP (required in SaaS mode — for verification, password reset, billing)
# EMAIL_FROM=noreply@yourdomain.com
# SMTP_HOST=localhost
# SMTP_PORT=587
# SMTP_USER=                         # Optional — leave blank for unauthenticated relay
# SMTP_PASS=                         # Optional
