# ============================================================================
# MATTIN AI — Single-host Docker deployment
# ============================================================================
# Sirve para desarrollo local y para despliegues en servidores de cliente.
# La única diferencia entre ambos es FRONTEND_URL y las credenciales.
#
# Uso:
#   1. cp .env.example .env
#   2. Editar las variables de abajo
#   3. docker compose up -d --build
# ============================================================================

# ----------------------------------------------------------------------------
# URL pública
# ----------------------------------------------------------------------------
# Local:     http://localhost
# Cliente:   http://<ip-o-dominio-del-servidor>
FRONTEND_URL=http://localhost

# Puerto en el que Caddy escucha en el host (cámbialo si 80 está ocupado)
HTTP_PORT=80

# Tag de las imágenes publicadas en GHCR que se descargarán con `docker compose pull`.
#   develop      → último build de la rama develop (por defecto)
#   sha-<hash>   → commit específico (p.ej. sha-c1feaaf) — recomendado en cliente
# Si prefieres construir en local desde código: `docker compose up -d --build`
IMAGE_TAG=develop

# ----------------------------------------------------------------------------
# Base de datos [REQUERIDO]
# ----------------------------------------------------------------------------
# DATABASE_PASSWORD no tiene valor por defecto: el compose falla si no lo
# defines aquí. Genera uno robusto (min 20 caracteres aleatorios).
DATABASE_USER=mattin
DATABASE_PASSWORD=
DATABASE_NAME=mattin_ai

# ----------------------------------------------------------------------------
# Autenticación [SECRET_KEY REQUERIDO]
# ----------------------------------------------------------------------------
# FAKE:  login por email (desarrollo/demos)
# LOCAL: SaaS con email+password
# OIDC:  Entra ID / Azure AD (producción)
AICT_LOGIN=FAKE

# SECRET_KEY no tiene valor por defecto: el compose falla si no lo defines.
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Emails separados por coma que serán omniadmin
AICT_OMNIADMINS=admin@example.com

# Solo si AICT_LOGIN=OIDC
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# ----------------------------------------------------------------------------
# Claves de proveedores de IA
# ----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# ----------------------------------------------------------------------------
# Base vectorial
# ----------------------------------------------------------------------------
# PGVECTOR (usa Postgres) o QDRANT
VECTOR_DB_TYPE=PGVECTOR
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_PREFER_GRPC=false

# ----------------------------------------------------------------------------
# Configuración de la aplicación
# ----------------------------------------------------------------------------
AICT_MODE=SELF-HOSTED
REPO_BASE_FOLDER=./data/repositories

# Modo de despliegue: self_managed (por defecto) o saas
# Solo cambiar a saas si vais a operar con suscripciones Stripe, tiers, etc.
# AICT_DEPLOYMENT_MODE=self_managed

# ----------------------------------------------------------------------------
# Observabilidad (opcional)
# ----------------------------------------------------------------------------
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# ----------------------------------------------------------------------------
# OIDC del frontend (solo si usáis OIDC)
# ----------------------------------------------------------------------------
VITE_OIDC_ENABLED=false
VITE_OIDC_AUTHORITY=
VITE_OIDC_CLIENT_ID=
VITE_OIDC_REDIRECT_URI=
VITE_OIDC_SCOPE=openid profile email
VITE_OIDC_AUDIENCE=
